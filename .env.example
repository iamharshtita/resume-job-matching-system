# OpenAI API (if using GPT-4o-mini)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama (if using local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Strands Agents SDK (if available)
STRANDS_API_KEY=your_strands_key_here

# Data Paths
DATA_DIR=./data
ONET_PATH=./data/raw/onet
RESUME_PATH=./data/raw/resumes_primary
JOB_PATH=./data/raw/job_postings

# Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm

# Scoring Weights
SKILL_WEIGHT=0.40
EXPERIENCE_WEIGHT=0.30
EDUCATION_WEIGHT=0.20
TITLE_WEIGHT=0.10

# API Limits
MAX_TOKENS=2000
TIMEOUT=30
MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO
LOG_FILE=./outputs/logs/app.log
